# VS Insurance - Environment Variables

# =================================
# GOOGLE ANALYTICS 4 (GA4)
# =================================
# Get your GA4 Measurement ID from: https://analytics.google.com/
# 1. Go to Admin → Data Streams → Choose your web stream
# 2. Copy the Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# =================================
# GOOGLE SEARCH CONSOLE
# =================================
# Get verification code from: https://search.google.com/search-console
# 1. Add property → URL prefix
# 2. Choose "HTML tag" verification method
# 3. Copy the content value from the meta tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code

# =================================
# SITE CONFIGURATION
# =================================
# Your production website URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.bharatcover.net

# =================================
# LANDING GUEST API (optional unified CDK stack in this repo)
# =================================
# Full base URL, no trailing slash. If unset, app/sales/* uses static data + query params
# unless you wire platformFetch() to the split URLs below.
NEXT_PUBLIC_API_URL=
# If NEXT_PUBLIC_API_URL is empty, frontend guest flow auto-routes by path to split stacks:
# - customer sales (sessions/default)
# - policy (guest policy fetch/update)
# - kyc (kyc paths)
# - payment (order + verify)
# - company (products)
# Guest payment verify: the checkout calls POST /api/guest/payments/verify (same origin), which
# proxies to {NEXT_PUBLIC_API_URL}/guest/payments/verify so the browser is not limited by API Gateway CORS
# (e.g. http://localhost:4000). Requires NEXT_PUBLIC_API_URL on the Next server.

# Razorpay — publishable Key Id (client Checkout.js). Use rzp_test_* in local dev.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
# API Key *Secret* (server) — the second half of the pair; NOT the same as NEXT_PUBLIC_RAZORPAY_KEY_ID.
# Required for /api/razorpay/checkout-order + checkout-verify. Dashboard → Test mode → API Keys → Reveal secret.
# (Optional alias: RAZORPAY_SECRET=…)
RAZORPAY_KEY_SECRET=
# Optional: override key id on server if different from NEXT_PUBLIC_RAZORPAY_KEY_ID
# RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
#
# Webhook signing secret — NOT the same as RAZORPAY_KEY_SECRET. Not required for the Pay button or /api/razorpay/*.
# Only for Razorpay → HTTP callback to your **landing** API: POST {ApiUrl}/webhooks/razorpay
# (Dashboard → Webhooks → add URL → copy the "Webhook secret" for that entry; or SSM …/razorpay-webhook-secret)
# RAZORPAY_WEBHOOK_SECRET=
#
# When NEXT_PUBLIC_API_URL is unset or there is no guest session, dev builds can still pay via
# Next.js → Razorpay (catalog prices only). Disable with NEXT_PUBLIC_CHECKOUT_DIRECT_RAZORPAY=false.
# Production: direct checkout is off unless NEXT_PUBLIC_CHECKOUT_DIRECT_RAZORPAY=true and
# ENABLE_CHECKOUT_DIRECT_RAZORPAY_IN_PRODUCTION=true on the server (discouraged).
NEXT_PUBLIC_CHECKOUT_DIRECT_RAZORPAY=
ENABLE_CHECKOUT_DIRECT_RAZORPAY_IN_PRODUCTION=

# Optional: sender used by Payments Lambda to email policy details after successful verify.
# Set during CDK deploy via env var LANDING_POLICY_EMAIL_FROM (must be SES-verified).
# LANDING_POLICY_EMAIL_FROM=policies@bharatcover.net

# =================================
# SUREPASS DIGILOCKER (server-only — never use NEXT_PUBLIC_* for the API key)
# =================================
# Used by app/api/surepass/digilocker/* and checkout step 0. Defaults match SurePass sandbox.
# SUREPASS_API_URL=https://sandbox.surepass.app
# SUREPASS_API_KEY=your_bearer_jwt_from_surepass_dashboard
# SUREPASS_ENV=sandbox
# Optional path overrides if your tenant uses different routes:
# SUREPASS_DIGILOCKER_INIT_PATH=/api/v1/digilocker/initialize
# SUREPASS_DIGILOCKER_STATUS_PATH=/api/v1/digilocker/status
# Extra allowed redirect origins (comma-separated full URLs) for previews, e.g. Vercel:
# SUREPASS_ALLOWED_REDIRECT_ORIGINS=https://your-app-git-branch.vercel.app
#
# redirect_url on initialize must match NEXT_PUBLIC_SITE_URL (or NEXT_PUBLIC_APP_URL / VERCEL_URL).

# =================================
# DUMMY DIGILOCKER / KYC (testing only)
# =================================
# Client: "Use Dummy KYC" shows when NODE_ENV !== production, unless you force:
# NEXT_PUBLIC_ALLOW_DUMMY_KYC=false   # hide dummy button even in dev
# NEXT_PUBLIC_ALLOW_DUMMY_KYC=true    # show dummy button in production builds (e.g. preview) — use sparingly
# Optional override for POST URL (default /api/kyc/dummy/save):
# NEXT_PUBLIC_DUMMY_KYC_SAVE_URL=/api/kyc/dummy/save
#
# Server POST /api/kyc/dummy/save is allowed when NODE_ENV !== production.
# To allow dummy save on a production Node server (dangerous), set:
# ALLOW_DUMMY_KYC_IN_PRODUCTION=true

# =================================
# INSURANCE PLATFORM — split API Gateways (us-east-1)
# =================================
# Stage guardrail used by lib/insurance-api-config.ts
# Allowed: raghu-development | production
NEXT_PUBLIC_BACKEND_STAGE=raghu-development

# Used by lib/insurance-api-config.ts + platformFetch(). Trailing slashes are normalized.
# Uncomment ONE block (production vs development) and paste your execute-api URLs.

# --- PRODUCTION (example — uncomment and fill when active)
# NEXT_PUBLIC_AUTH_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1
# NEXT_PUBLIC_CUSTOMER_SALES_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1
# NEXT_PUBLIC_POLICY_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1
# NEXT_PUBLIC_COMPANY_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1
# NEXT_PUBLIC_KYC_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1
# NEXT_PUBLIC_PAYMENT_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1
# NEXT_PUBLIC_TRUST_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1
# NEXT_PUBLIC_EMPLOYEE_API_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/v1

# --- DEVELOPMENT (paste your RAGHU-DEVELOPMENT / team dev URLs into .env locally)
NEXT_PUBLIC_AUTH_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1
NEXT_PUBLIC_CUSTOMER_SALES_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1
NEXT_PUBLIC_POLICY_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1
NEXT_PUBLIC_COMPANY_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1
NEXT_PUBLIC_KYC_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1
NEXT_PUBLIC_PAYMENT_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1
NEXT_PUBLIC_TRUST_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1
NEXT_PUBLIC_EMPLOYEE_API_URL=https://YOUR_DEV_API_ID.execute-api.us-east-1.amazonaws.com/v1

# CDN hostname only (no https://)
NEXT_PUBLIC_CDN_DOMAIN=YOUR_CLOUDFRONT_HOST.cloudfront.net

# =================================
# MONGODB
# =================================
# Copy to .env — never commit real credentials (.env is gitignored)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vs-insurance?retryWrites=true&w=majority

# =================================
# BUSINESS CONTACT INFORMATION
# =================================
# Update these in lib/seo-config.ts
# - Business name, address, phone
# - Social media links
# - Email address
