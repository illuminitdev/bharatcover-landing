# Core
STAGE=raghu-development
REGION=ap-south-1

# Stage resources (if not derived automatically)
USERS_TABLE=
CUSTOMERS_TABLE=
PRODUCTS_TABLE=
POLICIES_TABLE=
PAYMENTS_TABLE=
NOTIFICATIONS_TABLE=
SUBSCRIPTIONS_TABLE=

# Auth/Cognito (for post-payment account creation)
USER_POOL_ID=
CLIENT_ID=

# Payment
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Security
REGISTRATION_PASSWORD_ENCRYPTION_KEY=
ALLOWED_SALES_ORIGINS=

# Post-payment login handoff to the main BharatCover app
# (used by lambdas/sales/finalize-sales-customer-account.ts to mint a JWT
# the main app exchanges at /auth/handoff-exchange). MUST match the secret
# configured on the main-app deployment. 32+ random bytes; never log or
# expose to clients.
HANDOFF_JWT_SECRET=

# Sender used by SES for the post-payment "Your BharatCover Account
# Credentials" email (must be a verified SES identity).
POLICY_EMAIL_FROM=noreply@bharatcover.net

# Optional app metadata
SERVICE_NAME=insurance-platform
